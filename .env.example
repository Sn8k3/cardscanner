# --- eBay (Browse API) ---
# Register a free developer account and create a "Production" keyset at:
# https://developer.ebay.com/my/keys
# You only need the client credentials grant (app-level token), no user login required
# for public listing search.
EBAY_CLIENT_ID=your-ebay-client-id
EBAY_CLIENT_SECRET=your-ebay-client-secret
EBAY_MARKETPLACE_ID=EBAY_US

# --- Card catalog + TCGPlayer pricing (via pokemontcg.io) ---
# TCGPlayer's own API is closed to new developer signups as of 2026, so this
# project uses pokemontcg.io, which embeds TCGPlayer market/low/mid pricing
# on every card object. Free to use without a key at low volume; register at
# https://dev.pokemontcg.io for an API key and much higher rate limits.
POKEMONTCG_API_KEY=

# --- Search config ---
# Comma-separated eBay search terms to scan on each run.
SEARCH_QUERIES=charizard vmax,pikachu vmax,umbreon vmax alt art,moonbreon,charizard ex,giratina vstar,lugia v alt art
# Max eBay results to pull per query per scan (eBay allows up to 200 with paging).
RESULTS_PER_QUERY=50

# --- Server ---
PORT=8787
